#!/bin/sh
# Final guard: reject Cursor/agent attribution trailers on commits.
if grep -qiE '^(Co-authored-by:.*(cursor|cursoragent)|Made-with:.*cursor)' "$1"; then
  echo "ERROR: Cursor attribution is not allowed in this repository." >&2
  echo "Remove Co-authored-by / Made-with Cursor lines from the commit message." >&2
  exit 1
fi
